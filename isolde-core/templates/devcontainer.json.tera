{
  "name": "{{project_name}} - Development Environment",

  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "USERNAME": "${localEnv:USER}",
      "LANG_VERSION": "{{lang_version}}"
    }
  },

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "installOhMyZsh": false,
      "upgradePackages": false
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts",
      "nodeGypDependencies": true,
      "npxInstallCachedPackages": true
    },
    "{{features_proxy}}": {
      "http_proxy": "{{proxy_http}}",
      "https_proxy": "{{proxy_https}}",
      "no_proxy": "{{proxy_no_proxy}}",
      "enabled": {{proxy_enabled}}
    },
    "{{agent_feature_path}}": {{agent_options_json}}{{plugin_manager_block}}
  },

  "overrideFeatureInstallOrder": {{feature_install_order_json}},

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "postCreateCommand": "bash -c 'if [ -f ~/.config/devcontainer/provider ]; then sed -i \"s#local provider=\\\\\\\"#local provider=\\\\\\\"\\$(cat ~/.config/devcontainer/provider)\\\\\\\"#\" ~/.bashrc; fi'",

  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/${localEnv:USER}/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude.json,target=/home/${localEnv:USER}/.claude.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/devcontainer/machine-id,target=/etc/machine-id,type=bind,consistency=cached"
  ],

  "remoteUser": "${localEnv:USER}",
  "workspaceFolder": "/workspaces/{{project_name}}"
}
